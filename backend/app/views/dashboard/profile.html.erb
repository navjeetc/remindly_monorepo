<div class="max-w-2xl mx-auto">
  <div class="mb-6">
    <%= link_to "← Back to Dashboard", dashboard_path, class: "text-blue-600 hover:text-blue-800" %>
  </div>

  <div class="bg-white shadow sm:rounded-lg">
    <div class="px-4 py-5 sm:p-6">
      <h3 class="text-lg leading-6 font-medium text-gray-900 mb-6">
        My Profile
      </h3>

      <%= form_with model: current_user, url: profile_path, method: :patch, class: "space-y-6" do |f| %>
        <% if current_user.errors.any? %>
          <div class="rounded-md bg-red-50 p-4">
            <div class="text-sm text-red-700">
              <ul class="list-disc pl-5 space-y-1">
                <% current_user.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          </div>
        <% end %>

        <!-- Email (read-only) -->
        <div>
          <%= f.label :email, class: "block text-sm font-medium text-gray-700" %>
          <div class="mt-1 text-sm text-gray-900 bg-gray-50 px-3 py-2 rounded-md">
            <%= current_user.email %>
          </div>
          <p class="mt-1 text-xs text-gray-500">Email cannot be changed</p>
        </div>

        <!-- Name -->
        <div>
          <%= f.label :name, "Full Name", class: "block text-sm font-medium text-gray-700" %>
          <span class="text-red-500">*</span>
          <%= f.text_field :name, 
            class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm",
            placeholder: "e.g., John Smith",
            required: true %>
          <p class="mt-1 text-xs text-gray-500">Your full name (required)</p>
        </div>

        <!-- Nickname -->
        <div>
          <%= f.label :nickname, class: "block text-sm font-medium text-gray-700" %>
          <%= f.text_field :nickname, 
            class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm",
            placeholder: "e.g., Johnny, Grandma, etc." %>
          <p class="mt-1 text-xs text-gray-500">
            How you'd like others to call you. If not set, your name will be used.
          </p>
        </div>

        <!-- Timezone -->
        <div>
          <%= f.label :tz, "Timezone", class: "block text-sm font-medium text-gray-700" %>
          <%= f.select :tz,
            options_for_select(
              ActiveSupport::TimeZone.all.map { |tz| [tz.to_s, tz.name] },
              current_user.tz
            ),
            {},
            class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
        </div>

        <!-- Notification Preferences (Caregivers only) -->
        <% if current_user.role_caregiver? %>
          <div class="border-t border-gray-200 pt-6">
            <h4 class="text-base font-medium text-gray-900 mb-4">Notification Preferences</h4>
            
            <div class="space-y-4">
              <div class="relative flex items-start">
                <div class="flex items-center h-5">
                  <%= f.check_box :notify_on_task_assigned_to_others, 
                    class: "focus:ring-blue-500 h-4 w-4 text-blue-600 border-gray-300 rounded" %>
                </div>
                <div class="ml-3 text-sm">
                  <%= f.label :notify_on_task_assigned_to_others, class: "font-medium text-gray-700" do %>
                    Notify me when tasks are assigned to other caregivers
                  <% end %>
                  <p class="text-gray-500">You'll always be notified when a task is assigned to you. This setting controls whether you also want to know when tasks are assigned to others.</p>
                </div>
              </div>

              <fieldset>
                <legend class="font-medium text-gray-700">Tell me when a reminder is completed or missed</legend>
                <p class="text-gray-500 text-sm mb-3">Get an email and a dashboard alert when someone you care for completes a reminder, or misses it. Choose which kinds — hydration and routine reminders happen many times a day, so leave those off unless you want every one.</p>

                <%# An empty hidden value so unchecking every box submits an empty set. %>
                <%= hidden_field_tag "user[notify_reminder_categories][]", "" %>

                <div class="space-y-3">
                  <% Reminder.categories.keys.each do |category| %>
                    <div class="relative flex items-start">
                      <div class="flex items-center h-5">
                        <%= check_box_tag "user[notify_reminder_categories][]", category,
                          current_user.notify_reminder_categories.include?(category),
                          id: "notify_category_#{category}",
                          class: "focus:ring-blue-500 h-4 w-4 text-blue-600 border-gray-300 rounded" %>
                      </div>
                      <div class="ml-3 text-sm">
                        <%= label_tag "notify_category_#{category}", category.titleize, class: "font-medium text-gray-700" %>
                      </div>
                    </div>
                  <% end %>
                </div>
              </fieldset>
            </div>
          </div>
        <% end %>

        <!-- Role (read-only badge; the change control is its own form below) -->
        <% if current_user.role.present? %>
          <div>
            <%= f.label :role, class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1">
              <span class="inline-flex items-center px-3 py-2 rounded-md text-sm font-medium <%= current_user.role_senior? ? 'bg-blue-100 text-blue-800' : current_user.role_caregiver? ? 'bg-green-100 text-green-800' : 'bg-purple-100 text-purple-800' %>">
                <%= current_user.role.titleize %>
              </span>
            </div>
          </div>
        <% end %>

        <div class="flex justify-end space-x-3">
          <%= link_to "Cancel", dashboard_path, class: "inline-flex justify-center py-2 px-4 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" %>
          <%= f.submit "Save Changes", class: "inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700" %>
        </div>
      <% end %>

      <%# Role change is its own form (button_to) so it isn't nested in the profile
          form above. Admins manage roles from the admin panel, not here. %>
      <% unless current_user.role_admin? %>
        <div class="mt-8 border-t border-gray-200 pt-6">
          <h4 class="text-base font-medium text-gray-900 mb-2">Your role</h4>
          <% if current_user.role.present? %>
            <% other = current_user.role_senior? ? "caregiver" : "senior" %>
            <p class="text-sm text-gray-500 mb-3">
              You're set up as a <strong><%= current_user.role.titleize %></strong>.
              If that's not right, you can switch to <%= other %>.
            </p>
            <%= button_to "Switch to #{other.titleize}", select_role_path, method: :patch, params: { role: other },
              form: { data: { turbo_confirm: "Switch your role to #{other}? Your reminders and links stay as they are." } },
              class: "inline-flex justify-center py-2 px-4 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" %>
          <% else %>
            <p class="text-sm text-gray-500 mb-3">Choose whether you receive reminders or set them up for someone.</p>
            <div class="flex flex-wrap gap-3">
              <%= button_to "I'm a caregiver", select_role_path, method: :patch, params: { role: "caregiver" },
                class: "inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700" %>
              <%= button_to "I receive reminders", select_role_path, method: :patch, params: { role: "senior" },
                class: "inline-flex justify-center py-2 px-4 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
