<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="md:flex md:items-center md:justify-between mb-6">
    <div class="flex-1 min-w-0">
      <h2 class="text-2xl font-bold leading-7 text-gray-900 sm:text-3xl sm:truncate">
        🚫 Blocked Times for <%= @senior.display_name %>
      </h2>
      <p class="mt-1 text-sm text-gray-500">
        Manage unavailable time periods when <%= @senior.display_name %> cannot be scheduled for tasks
      </p>
    </div>
    <div class="mt-4 flex md:mt-0 md:ml-4">
      <%= link_to "← Back to Tasks", senior_tasks_path(@senior), class: "mr-3 inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50" %>
      <%= link_to "+ New Time Block", new_senior_time_block_path(@senior), class: "inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700" %>
    </div>
  </div>

  <% if @time_blocks.any? %>
    <div class="bg-white shadow overflow-hidden sm:rounded-md">
      <ul role="list" class="divide-y divide-gray-200">
        <% @time_blocks.each do |time_block| %>
          <li>
            <div class="px-4 py-4 sm:px-6">
              <div class="flex items-center justify-between">
                <div class="flex-1">
                  <div class="flex items-center">
                    <span class="text-2xl mr-3">🚫</span>
                    <div>
                      <p class="text-sm font-medium text-gray-900">
                        <%= time_block.reason.presence || "Blocked Time" %>
                        <% if time_block.recurring? %>
                          <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-purple-100 text-purple-800">
                            🔄 Recurring
                          </span>
                        <% end %>
                      </p>
                      <p class="mt-1 text-sm text-gray-500">
                        <%= time_block.start_time.strftime("%b %d, %Y at %I:%M %p") %> 
                        → 
                        <%= time_block.end_time.strftime("%b %d, %Y at %I:%M %p") %>
                      </p>
                      <% if time_block.recurrence_pattern.present? %>
                        <p class="mt-1 text-xs text-gray-400">
                          Pattern: <%= time_block.recurrence_pattern %>
                        </p>
                      <% end %>
                    </div>
                  </div>
                </div>
                <div class="flex items-center space-x-2">
                  <%= link_to "Edit", edit_senior_time_block_path(@senior, time_block), class: "inline-flex items-center px-3 py-1 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" %>
                  <%= button_to "Delete", senior_time_block_path(@senior, time_block), method: :delete, data: { confirm: "Are you sure?" }, class: "inline-flex items-center px-3 py-1 border border-transparent text-sm font-medium rounded-md text-white bg-red-600 hover:bg-red-700" %>
                </div>
              </div>
            </div>
          </li>
        <% end %>
      </ul>
    </div>
  <% else %>
    <div class="text-center py-12 bg-white rounded-lg shadow">
      <span class="text-6xl">🚫</span>
      <h3 class="mt-2 text-sm font-medium text-gray-900">No blocked times</h3>
      <p class="mt-1 text-sm text-gray-500">
        Get started by creating a new time block.
      </p>
      <div class="mt-6">
        <%= link_to "+ New Time Block", new_senior_time_block_path(@senior), class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700" %>
      </div>
    </div>
  <% end %>
</div>
