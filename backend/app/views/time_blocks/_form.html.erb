<%= form_with(model: @time_block, url: @time_block.persisted? ? senior_time_block_path(@senior, @time_block) : senior_time_blocks_path(@senior), class: "space-y-6") do |f| %>
  <% if @time_block.errors.any? %>
    <div class="rounded-md bg-red-50 p-4">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">
            <%= pluralize(@time_block.errors.count, "error") %> prohibited this time block from being saved:
          </h3>
          <div class="mt-2 text-sm text-red-700">
            <ul class="list-disc pl-5 space-y-1">
              <% @time_block.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
    <!-- Reason -->
    <div class="sm:col-span-2">
      <%= f.label :reason, "Reason (Optional)", class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :reason, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm", placeholder: "e.g., Sleep time, Meal time, Appointment" %>
    </div>

    <!-- Start Time -->
    <div>
      <%= f.label :start_time, "Start Time", class: "block text-sm font-medium text-gray-700" %>
      <%= f.datetime_local_field :start_time, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
    </div>

    <!-- End Time -->
    <div>
      <%= f.label :end_time, "End Time", class: "block text-sm font-medium text-gray-700" %>
      <%= f.datetime_local_field :end_time, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
    </div>

    <!-- Recurring -->
    <div class="sm:col-span-2">
      <div class="flex items-start">
        <div class="flex items-center h-5">
          <%= f.check_box :recurring, class: "h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" %>
        </div>
        <div class="ml-3 text-sm">
          <%= f.label :recurring, class: "font-medium text-gray-700" do %>
            🔄 Mark as recurring
          <% end %>
          <p class="text-gray-500">Indicates this is a recurring unavailability (pattern stored for reference)</p>
        </div>
      </div>
    </div>

    <!-- Recurrence Pattern -->
    <div class="sm:col-span-2">
      <%= f.label :recurrence_pattern, "Recurrence Pattern (Optional)", class: "block text-sm font-medium text-gray-700" %>
      <%= f.select :recurrence_pattern,
        options_for_select([
          ["Daily", "Daily"],
          ["Weekdays (Mon-Fri)", "Weekdays"],
          ["Weekends (Sat-Sun)", "Weekends"],
          ["Weekly", "Weekly"],
          ["Every Night", "Every Night"]
        ], @time_block.recurrence_pattern),
        { include_blank: "Select pattern" },
        class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
      <p class="mt-1 text-sm text-gray-500">Only used if recurring is checked</p>
    </div>

    <!-- Active -->
    <div class="sm:col-span-2">
      <div class="flex items-start">
        <div class="flex items-center h-5">
          <%= f.check_box :active, class: "h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" %>
        </div>
        <div class="ml-3 text-sm">
          <%= f.label :active, class: "font-medium text-gray-700" do %>
            ✅ Active
          <% end %>
          <p class="text-gray-500">Uncheck to temporarily disable this block without deleting it</p>
        </div>
      </div>
    </div>
  </div>

  <div class="flex justify-end space-x-3">
    <%= link_to "Cancel", senior_time_blocks_path(@senior), class: "inline-flex justify-center py-2 px-4 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" %>
    <%= f.submit @time_block.persisted? ? "Update Time Block" : "Create Time Block", class: "inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700" %>
  </div>
<% end %>
