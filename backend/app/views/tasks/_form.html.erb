<%= form_with(model: @task, url: @task.persisted? ? senior_task_path(@senior, @task) : senior_tasks_path(@senior), class: "space-y-6") do |f| %>
  <% if @task.errors.any? %>
    <div class="rounded-md bg-red-50 p-4">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">
            <%= pluralize(@task.errors.count, "error") %> prohibited this task from being saved:
          </h3>
          <div class="mt-2 text-sm text-red-700">
            <ul class="list-disc pl-5 space-y-1">
              <% @task.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
    <!-- Title -->
    <div class="sm:col-span-2">
      <%= f.label :title, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :title, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm", placeholder: "e.g., Doctor Appointment" %>
    </div>

    <!-- Task Type -->
    <div>
      <%= f.label :task_type, class: "block text-sm font-medium text-gray-700" %>
      <%= f.select :task_type, 
        options_for_select([
          ["Appointment", "appointment"],
          ["Errand", "errand"],
          ["Activity", "activity"],
          ["Household", "household"],
          ["Transportation", "transportation"],
          ["Other", "other"]
        ], @task.task_type),
        {},
        class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
    </div>

    <!-- Priority -->
    <div>
      <%= f.label :priority, class: "block text-sm font-medium text-gray-700" %>
      <%= f.select :priority, 
        options_for_select([
          ["Low", "low"],
          ["Medium", "medium"],
          ["High", "high"],
          ["Urgent", "urgent"]
        ], @task.priority),
        {},
        class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
    </div>

    <!-- Open-Ended Task Toggle -->
    <div class="sm:col-span-2">
      <div class="flex items-start">
        <div class="flex items-center h-5">
          <input type="checkbox" id="open_ended_toggle" class="h-4 w-4 text-purple-600 focus:ring-purple-500 border-gray-300 rounded" <%= 'checked' if @task.scheduled_at.nil? %>>
        </div>
        <div class="ml-3 text-sm">
          <label for="open_ended_toggle" class="font-medium text-purple-700">
            📋 Make this an open-ended task (no specific date)
          </label>
          <p class="text-gray-500">Open-ended tasks can be claimed by caregivers when they're available</p>
        </div>
      </div>
    </div>

    <!-- Scheduled Date/Time -->
    <div class="sm:col-span-2" id="scheduled_at_field">
      <%= f.label :scheduled_at, "Scheduled Date/Time", class: "block text-sm font-medium text-gray-700" %>
      <%= f.datetime_local_field :scheduled_at, id: "task_scheduled_at_input", class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
    </div>

    <script>
      document.addEventListener('DOMContentLoaded', function() {
        const openEndedToggle = document.getElementById('open_ended_toggle');
        const scheduledAtField = document.getElementById('scheduled_at_field');
        const scheduledAtInput = document.getElementById('task_scheduled_at_input');

        function getDefaultDateTime() {
          // Set to tomorrow at 9:00 AM
          const tomorrow = new Date();
          tomorrow.setDate(tomorrow.getDate() + 1);
          tomorrow.setHours(9, 0, 0, 0);
          
          // Format for datetime-local input: YYYY-MM-DDTHH:MM
          const year = tomorrow.getFullYear();
          const month = String(tomorrow.getMonth() + 1).padStart(2, '0');
          const day = String(tomorrow.getDate()).padStart(2, '0');
          const hours = String(tomorrow.getHours()).padStart(2, '0');
          const minutes = String(tomorrow.getMinutes()).padStart(2, '0');
          
          return `${year}-${month}-${day}T${hours}:${minutes}`;
        }

        function updateScheduledAtField() {
          if (openEndedToggle.checked) {
            scheduledAtField.style.display = 'none';
            scheduledAtInput.value = '';
            scheduledAtInput.disabled = true;
          } else {
            scheduledAtField.style.display = 'block';
            scheduledAtInput.disabled = false;
            
            // Set default date/time if field is empty
            if (!scheduledAtInput.value) {
              scheduledAtInput.value = getDefaultDateTime();
            }
          }
        }

        // Initialize on page load
        updateScheduledAtField();

        // Update when checkbox changes
        openEndedToggle.addEventListener('change', updateScheduledAtField);
      });
    </script>

    <script>
      // Recurrence pattern builder
      document.addEventListener('DOMContentLoaded', function() {
        const patternSelect = document.getElementById('recurrence_pattern');
        const dailyOptions = document.getElementById('daily_options');
        const weeklyOptions = document.getElementById('weekly_options');
        const monthlyOptions = document.getElementById('monthly_options');
        const recurrenceTime = document.getElementById('recurrence_time');
        const recurrencePreview = document.getElementById('recurrence_preview');
        const previewText = document.getElementById('preview_text');
        const rruleField = document.getElementById('rrule_field');
        const startTimeField = document.getElementById('start_time_field');

        function updateRecurrenceUI() {
          const pattern = patternSelect.value;
          
          // Hide all options
          dailyOptions.classList.add('hidden');
          weeklyOptions.classList.add('hidden');
          monthlyOptions.classList.add('hidden');
          recurrenceTime.classList.add('hidden');
          recurrencePreview.classList.add('hidden');

          if (pattern) {
            recurrenceTime.classList.remove('hidden');
            
            if (pattern === 'daily') {
              dailyOptions.classList.remove('hidden');
            } else if (pattern === 'weekly') {
              weeklyOptions.classList.remove('hidden');
            } else if (pattern === 'monthly') {
              monthlyOptions.classList.remove('hidden');
            }
            
            recurrencePreview.classList.remove('hidden');
          }

          buildRRule();
        }

        function buildRRule() {
          const pattern = patternSelect.value;
          if (!pattern) {
            rruleField.value = '';
            startTimeField.value = '';
            return;
          }

          const timeInput = document.getElementById('recurrence_time_input');
          const [hours, minutes] = timeInput.value.split(':');
          
          let rrule = '';
          let preview = '';

          if (pattern === 'daily') {
            const interval = document.getElementById('daily_interval').value;
            rrule = `FREQ=DAILY;INTERVAL=${interval};BYHOUR=${hours};BYMINUTE=${minutes}`;
            preview = interval == 1 ? `Every day at ${timeInput.value}` : `Every ${interval} days at ${timeInput.value}`;
          } else if (pattern === 'weekly') {
            const days = Array.from(document.querySelectorAll('input[name="weekly_days"]:checked'))
              .map(cb => cb.value);
            
            if (days.length > 0) {
              rrule = `FREQ=WEEKLY;BYDAY=${days.join(',')};BYHOUR=${hours};BYMINUTE=${minutes}`;
              const dayNames = days.map(d => {
                const names = {SU: 'Sun', MO: 'Mon', TU: 'Tue', WE: 'Wed', TH: 'Thu', FR: 'Fri', SA: 'Sat'};
                return names[d];
              });
              preview = `Weekly on ${dayNames.join(', ')} at ${timeInput.value}`;
            } else {
              preview = 'Select at least one day';
            }
          } else if (pattern === 'monthly') {
            const day = document.getElementById('monthly_day').value;
            rrule = `FREQ=MONTHLY;BYMONTHDAY=${day};BYHOUR=${hours};BYMINUTE=${minutes}`;
            preview = `Monthly on day ${day} at ${timeInput.value}`;
          }

          rruleField.value = rrule;
          previewText.textContent = preview;

          // Set start_time to today at the selected time
          const now = new Date();
          const year = now.getFullYear();
          const month = String(now.getMonth() + 1).padStart(2, '0');
          const day = String(now.getDate()).padStart(2, '0');
          startTimeField.value = `${year}-${month}-${day}T${hours}:${minutes}:00`;
        }

        // Event listeners
        patternSelect.addEventListener('change', updateRecurrenceUI);
        document.getElementById('daily_interval').addEventListener('input', buildRRule);
        document.getElementById('monthly_day').addEventListener('input', buildRRule);
        document.getElementById('recurrence_time_input').addEventListener('change', buildRRule);
        
        document.querySelectorAll('input[name="weekly_days"]').forEach(checkbox => {
          checkbox.addEventListener('change', buildRRule);
        });

        // Initialize
        updateRecurrenceUI();
      });
    </script>

    <!-- Duration -->
    <div>
      <%= f.label :duration_minutes, "Duration (minutes)", class: "block text-sm font-medium text-gray-700" %>
      <%= f.number_field :duration_minutes, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm", placeholder: "60" %>
    </div>

    <!-- Location -->
    <div class="sm:col-span-2">
      <%= f.label :location, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :location, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm", placeholder: "e.g., Main St Clinic, 123 Main St" %>
    </div>

    <!-- Assigned To -->
    <div>
      <%= f.label :assigned_to_id, "Assign to", class: "block text-sm font-medium text-gray-700" %>
      <%= f.select :assigned_to_id, 
        options_for_select([["Unassigned", nil]] + @caregivers.map { |c| [c.email, c.id] }, @task.assigned_to_id),
        {},
        class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
    </div>

    <!-- Status (only show for existing tasks) -->
    <% if @task.persisted? %>
      <div>
        <%= f.label :status, class: "block text-sm font-medium text-gray-700" %>
        <%= f.select :status, 
          options_for_select([
            ["Pending", "pending"],
            ["Assigned", "assigned"],
            ["In Progress", "in_progress"],
            ["Completed", "completed"],
            ["Cancelled", "cancelled"]
          ], @task.status),
          {},
          class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
      </div>
    <% end %>

    <!-- Description -->
    <div class="sm:col-span-2">
      <%= f.label :description, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_area :description, rows: 3, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm", placeholder: "Additional details about the task..." %>
    </div>

    <!-- Notes -->
    <div class="sm:col-span-2">
      <%= f.label :notes, "Notes/Instructions", class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_area :notes, rows: 2, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm", placeholder: "Important notes or instructions..." %>
    </div>

    <!-- Visible to Senior -->
    <div class="sm:col-span-2">
      <div class="flex items-start">
        <div class="flex items-center h-5">
          <%= f.check_box :visible_to_senior, class: "h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" %>
        </div>
        <div class="ml-3 text-sm">
          <%= f.label :visible_to_senior, class: "font-medium text-gray-700" do %>
            Show this task to senior on their dashboard
          <% end %>
          <p class="text-gray-500">Uncheck to hide this task from the senior (useful to avoid overwhelming them with too many tasks)</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Recurrence Section -->
  <div class="border-t border-gray-200 pt-6">
    <h3 class="text-lg font-medium text-gray-900 mb-4">🔄 Recurrence (Optional)</h3>
    
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
      <!-- Recurrence Pattern -->
      <div class="sm:col-span-2">
        <label class="block text-sm font-medium text-gray-700">Repeat</label>
        <select id="recurrence_pattern" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm">
          <option value="">Does not repeat</option>
          <option value="daily">Daily</option>
          <option value="weekly">Weekly</option>
          <option value="monthly">Monthly</option>
        </select>
      </div>

      <!-- Daily Options -->
      <div id="daily_options" class="sm:col-span-2 hidden">
        <label class="block text-sm font-medium text-gray-700 mb-2">Every</label>
        <div class="flex items-center space-x-2">
          <input type="number" id="daily_interval" value="1" min="1" max="30" class="w-20 rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm">
          <span class="text-sm text-gray-700">day(s)</span>
        </div>
      </div>

      <!-- Weekly Options -->
      <div id="weekly_options" class="sm:col-span-2 hidden">
        <label class="block text-sm font-medium text-gray-700 mb-2">Repeat on</label>
        <div class="flex flex-wrap gap-2">
          <label class="inline-flex items-center px-3 py-2 border border-gray-300 rounded-md cursor-pointer hover:bg-gray-50">
            <input type="checkbox" name="weekly_days" value="SU" class="rounded border-gray-300 text-blue-600 focus:ring-blue-500 mr-2">
            <span class="text-sm">Sun</span>
          </label>
          <label class="inline-flex items-center px-3 py-2 border border-gray-300 rounded-md cursor-pointer hover:bg-gray-50">
            <input type="checkbox" name="weekly_days" value="MO" class="rounded border-gray-300 text-blue-600 focus:ring-blue-500 mr-2">
            <span class="text-sm">Mon</span>
          </label>
          <label class="inline-flex items-center px-3 py-2 border border-gray-300 rounded-md cursor-pointer hover:bg-gray-50">
            <input type="checkbox" name="weekly_days" value="TU" class="rounded border-gray-300 text-blue-600 focus:ring-blue-500 mr-2">
            <span class="text-sm">Tue</span>
          </label>
          <label class="inline-flex items-center px-3 py-2 border border-gray-300 rounded-md cursor-pointer hover:bg-gray-50">
            <input type="checkbox" name="weekly_days" value="WE" class="rounded border-gray-300 text-blue-600 focus:ring-blue-500 mr-2">
            <span class="text-sm">Wed</span>
          </label>
          <label class="inline-flex items-center px-3 py-2 border border-gray-300 rounded-md cursor-pointer hover:bg-gray-50">
            <input type="checkbox" name="weekly_days" value="TH" class="rounded border-gray-300 text-blue-600 focus:ring-blue-500 mr-2">
            <span class="text-sm">Thu</span>
          </label>
          <label class="inline-flex items-center px-3 py-2 border border-gray-300 rounded-md cursor-pointer hover:bg-gray-50">
            <input type="checkbox" name="weekly_days" value="FR" class="rounded border-gray-300 text-blue-600 focus:ring-blue-500 mr-2">
            <span class="text-sm">Fri</span>
          </label>
          <label class="inline-flex items-center px-3 py-2 border border-gray-300 rounded-md cursor-pointer hover:bg-gray-50">
            <input type="checkbox" name="weekly_days" value="SA" class="rounded border-gray-300 text-blue-600 focus:ring-blue-500 mr-2">
            <span class="text-sm">Sat</span>
          </label>
        </div>
      </div>

      <!-- Monthly Options -->
      <div id="monthly_options" class="sm:col-span-2 hidden">
        <label class="block text-sm font-medium text-gray-700 mb-2">On day</label>
        <input type="number" id="monthly_day" value="1" min="1" max="31" class="w-24 rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm">
        <span class="text-sm text-gray-500 ml-2">of the month</span>
      </div>

      <!-- Time Selection -->
      <div id="recurrence_time" class="sm:col-span-2 hidden">
        <label class="block text-sm font-medium text-gray-700">Time</label>
        <input type="time" id="recurrence_time_input" value="09:00" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm">
      </div>

      <!-- Preview -->
      <div id="recurrence_preview" class="sm:col-span-2 hidden">
        <div class="bg-green-50 border-l-4 border-green-400 p-3">
          <p class="text-sm text-green-700">
            <strong>Preview:</strong> <span id="preview_text"></span>
          </p>
        </div>
      </div>
    </div>

    <!-- Hidden fields for actual form submission -->
    <%= f.hidden_field :rrule, id: "rrule_field" %>
    <%= f.hidden_field :tz, value: @senior.tz, id: "tz_field" %>
    <%= f.hidden_field :start_time, id: "start_time_field" %>
  </div>

  <div class="flex justify-end space-x-3">
    <%= link_to "Cancel", @task.persisted? ? senior_task_path(@senior, @task) : senior_tasks_path(@senior), class: "inline-flex justify-center py-2 px-4 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
    <%= f.submit @task.persisted? ? "Update Task" : "Create Task", class: "inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
  </div>
<% end %>
