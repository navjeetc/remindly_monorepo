<div class="space-y-6">
  <div class="flex justify-between items-center">
    <div>
      <h2 class="text-3xl font-bold text-gray-900">Tasks for <%= @senior.email %></h2>
      <p class="mt-1 text-sm text-gray-500">Manage appointments, errands, and activities</p>
    </div>
    <div class="flex space-x-4">
      <%= link_to "New Task", new_senior_task_path(@senior), class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700" %>
      <%= link_to "← Back to Dashboard", senior_dashboard_path(@senior), class: "text-blue-600 hover:text-blue-800" %>
    </div>
  </div>

  <!-- Senior Visibility Info -->
  <div class="bg-blue-50 border-l-4 border-blue-400 p-4">
    <div class="flex">
      <div class="flex-shrink-0">
        <svg class="h-5 w-5 text-blue-400" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
        </svg>
      </div>
      <div class="ml-3">
        <h3 class="text-sm font-medium text-blue-800">Senior Dashboard Visibility</h3>
        <div class="mt-2 text-sm text-blue-700">
          <p class="mb-2">Tasks appear on the senior's dashboard when they meet these criteria:</p>
          <ul class="list-disc list-inside space-y-1 ml-2">
            <li>✅ Task has <code class="bg-blue-100 px-1 rounded">visible_to_senior: true</code> (defaults to true)</li>
            <li>✅ Task is scheduled within next 30 days</li>
            <li>✅ Task status is not 'completed'</li>
            <li>✅ Scheduled date is today or in the future</li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <!-- Filters -->
  <div class="bg-white shadow sm:rounded-lg p-4">
    <%= form_with url: senior_tasks_path(@senior), method: :get, class: "grid grid-cols-1 gap-4 sm:grid-cols-6" do |f| %>
      <div>
        <%= f.label :view, "View", class: "block text-sm font-medium text-gray-700" %>
        <%= f.select :view, 
          options_for_select([
            ["Scheduled Tasks", ""],
            ["Upcoming", "upcoming"],
            ["Past", "past"],
            ["Open-Ended", "open_ended"]
          ], params[:view]),
          {}, 
          class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
      </div>

      <div>
        <%= f.label :status, "Status", class: "block text-sm font-medium text-gray-700" %>
        <%= f.select :status, 
          options_for_select([
            ["All Statuses", ""],
            ["Pending", "pending"],
            ["Assigned", "assigned"],
            ["In Progress", "in_progress"],
            ["Completed", "completed"],
            ["Cancelled", "cancelled"]
          ], params[:status]),
          {}, 
          class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
      </div>

      <div>
        <%= f.label :task_type, "Type", class: "block text-sm font-medium text-gray-700" %>
        <%= f.select :task_type, 
          options_for_select([
            ["All Types", ""],
            ["Appointment", "appointment"],
            ["Errand", "errand"],
            ["Activity", "activity"],
            ["Household", "household"],
            ["Transportation", "transportation"],
            ["Other", "other"]
          ], params[:task_type]),
          {}, 
          class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
      </div>

      <div>
        <%= f.label :priority, "Priority", class: "block text-sm font-medium text-gray-700" %>
        <%= f.select :priority, 
          options_for_select([
            ["All Priorities", ""],
            ["Low", "low"],
            ["Medium", "medium"],
            ["High", "high"],
            ["Urgent", "urgent"]
          ], params[:priority]),
          {}, 
          class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
      </div>

      <div>
        <%= f.label :external_source, "Source", class: "block text-sm font-medium text-gray-700" %>
        <%= f.select :external_source, 
          options_for_select([
            ["All Sources", ""],
            ["Manual", "manual"],
            ["Acuity", "acuity"],
            ["Calendly", "calendly"]
          ], params[:external_source]),
          {}, 
          class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" %>
      </div>

      <div class="flex items-end">
        <%= f.submit "Filter", class: "w-full inline-flex justify-center items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-gray-600 hover:bg-gray-700" %>
      </div>
    <% end %>
  </div>

  <!-- Open-Ended Tasks Section -->
  <% if @open_ended_tasks.any? && params[:view] != "open_ended" %>
    <div class="bg-purple-50 border-l-4 border-purple-400 p-4 mb-6">
      <div class="flex items-start">
        <div class="flex-shrink-0">
          <svg class="h-6 w-6 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <div class="ml-3 flex-1">
          <h3 class="text-sm font-medium text-purple-800">📋 Open-Ended Tasks (<%= @open_ended_tasks.count %>)</h3>
          <p class="mt-1 text-sm text-purple-700">Tasks without specific dates that caregivers can claim when available</p>
          <div class="mt-3 space-y-2">
            <% @open_ended_tasks.first(3).each do |task| %>
              <div class="bg-white rounded p-3 shadow-sm">
                <%= link_to senior_task_path(@senior, task), class: "block" do %>
                  <div class="flex items-center justify-between">
                    <span class="font-medium text-gray-900"><%= task.title %></span>
                    <div class="flex items-center space-x-2">
                      <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-purple-100 text-purple-800">
                        <%= task.task_type.titleize %>
                      </span>
                      <% if task.assigned_to %>
                        <span class="text-xs text-green-600">Assigned to <%= task.assigned_to.friendly_name %></span>
                      <% else %>
                        <span class="text-xs text-gray-400 italic">Unassigned</span>
                      <% end %>
                    </div>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
          <% if @open_ended_tasks.count > 3 %>
            <div class="mt-3">
              <%= link_to "View all #{@open_ended_tasks.count} open-ended tasks →", senior_tasks_path(@senior, view: "open_ended"), class: "text-sm font-medium text-purple-600 hover:text-purple-800" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Tasks List -->
  <% if @tasks.any? %>
    <div class="bg-white shadow overflow-hidden sm:rounded-md">
      <ul role="list" class="divide-y divide-gray-200">
        <% @tasks.each do |task| %>
          <li>
            <%= link_to senior_task_path(@senior, task), class: "block hover:bg-gray-50" do %>
              <div class="px-4 py-4 sm:px-6">
                <div class="flex items-center justify-between">
                  <div class="flex items-center">
                    <!-- Task Type Icon -->
                    <div class="flex-shrink-0 mr-3">
                      <% case task.task_type %>
                      <% when "appointment" %>
                        <svg class="h-6 w-6 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
                        </svg>
                      <% when "errand" %>
                        <svg class="h-6 w-6 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
                        </svg>
                      <% when "activity" %>
                        <svg class="h-6 w-6 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                      <% when "transportation" %>
                        <svg class="h-6 w-6 text-yellow-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/>
                        </svg>
                      <% else %>
                        <svg class="h-6 w-6 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                        </svg>
                      <% end %>
                    </div>

                    <div class="min-w-0 flex-1">
                      <div class="flex items-center gap-2">
                        <p class="text-sm font-medium text-gray-900 truncate"><%= task.title %></p>
                        <% if task.external_appointment? %>
                          <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-purple-100 text-purple-800">
                            🔗 <%= task.external_provider_name %>
                          </span>
                        <% end %>
                      </div>
                      <p class="text-sm text-gray-500">
                        <% if task.scheduled_at.present? %>
                          <%= task.scheduled_at.strftime("%b %d, %Y at %I:%M %p") %>
                        <% else %>
                          <span class="text-purple-600 font-medium">Open-ended (no date)</span>
                        <% end %>
                        <% if task.location.present? %>
                          • <%= task.location %>
                        <% end %>
                      </p>
                    </div>
                  </div>

                  <div class="flex items-center space-x-2">
                    <!-- Priority Badge -->
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                      <%= case task.priority
                          when 'urgent' then 'bg-red-100 text-red-800'
                          when 'high' then 'bg-orange-100 text-orange-800'
                          when 'medium' then 'bg-yellow-100 text-yellow-800'
                          else 'bg-gray-100 text-gray-800'
                          end %>">
                      <%= task.priority.titleize %>
                    </span>

                    <!-- Status Badge -->
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                      <%= case task.status
                          when 'completed' then 'bg-green-100 text-green-800'
                          when 'in_progress' then 'bg-blue-100 text-blue-800'
                          when 'assigned' then 'bg-purple-100 text-purple-800'
                          when 'cancelled' then 'bg-gray-100 text-gray-800'
                          else 'bg-yellow-100 text-yellow-800'
                          end %>">
                      <%= task.status.titleize.gsub('_', ' ') %>
                    </span>

                    <% if task.assigned_to %>
                      <span class="text-xs text-gray-500">
                        Assigned to <%= task.assigned_to.email.split('@').first %>
                      </span>
                    <% else %>
                      <span class="text-xs text-gray-400 italic">Unassigned</span>
                    <% end %>
                  </div>
                </div>
              </div>
            <% end %>
          </li>
        <% end %>
      </ul>
    </div>

    <!-- Pagination -->
    <div class="flex justify-center">
      <%= paginate @tasks %>
    </div>
  <% else %>
    <div class="text-center py-12 bg-white rounded-lg shadow">
      <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
      </svg>
      <h3 class="mt-2 text-sm font-medium text-gray-900">No tasks found</h3>
      <p class="mt-1 text-sm text-gray-500">Get started by creating a new task.</p>
      <div class="mt-6">
        <%= link_to "New Task", new_senior_task_path(@senior), class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700" %>
      </div>
    </div>
  <% end %>
</div>
